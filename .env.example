# Environment Configuration
ENVIRONMENT=development
DEBUG=True

# Data Paths
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_EMBEDDINGS_PATH=data/embeddings

# Model Configuration
MODEL_NAME=bert-base-uncased
MAX_SEQUENCE_LENGTH=512
BATCH_SIZE=32
EPOCHS=5
LEARNING_RATE=2e-5

# RAG Configuration
RAG_ENABLED=True
RETRIEVER_TYPE=faiss
VECTOR_DIMENSION=768
TOP_K_RESULTS=5

# Vector Database (Pinecone)
PINECONE_API_KEY=your_api_key_here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=ticket-embeddings

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=ticket-classification

# Azure Deployment (optional)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=your_resource_group
AZURE_MODEL_NAME=ticket-classifier
AZURE_DEPLOYMENT_NAME=ticket-classifier-prod

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Database (if using)
DATABASE_URL=sqlite:///./ticket_db.db
